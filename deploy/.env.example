# Mynet 部署配置模板
# 方式一（推荐）: 运行 ./config.sh 进行交互式配置
# 方式二: 复制此文件为 .env 并手动填入真实值，然后运行 ./install.sh

# ----- 域名（必填）-----
# 指向本机公网 IP 的域名
DOMAIN=vpn.example.com

# ----- 反向代理 -----
# 是否使用 Caddy 作为反向代理（true/false）
# 关闭后 Headscale 和 Headplane 将直接暴露端口
USE_CADDY=true

# ----- 证书管理 -----
# auto   = 自动通过 Let's Encrypt (acme.sh) 申请证书（需要 USE_CADDY=true）
# manual = 不申请证书，使用 HTTP（Caddy 模式）/ 自签名证书（DERP）
CERT_MODE=auto

# ACME 邮箱（仅 CERT_MODE=auto 时需要）
ACME_EMAIL=admin@example.com

# DNS API 凭证（可选 — 用于 DNS-01 质询，避免占用 80 端口）
# 支持: cf (Cloudflare), ali (Aliyun), dgon (DNSPod), he (Hurricane Electric)
# 完整列表: https://github.com/acmesh-official/acme.sh/wiki/dnsapi
DNS_API_PROVIDER=
DNS_API_CREDENTIALS=

# ----- Headplane -----
# Cookie 加密密钥（32 字符随机字符串，切勿泄露）
# 生成方式: openssl rand -hex 16
COOKIE_SECRET=change-me-to-a-random-32-char-string

# Headscale API 密钥（首次部署可留空，稍后通过 headscale apikeys create 生成）
HEADSCALE_API_KEY=

# ----- DERP 端口 -----
# DERP 服务对外端口（建议保持默认值）
DERP_PORT=3340
STUN_PORT=3478

# DERP 独立域名（可选 — 留空则使用主域名 DOMAIN）
# 用于 DERP 中继服务器的 TLS 证书和客户端连接地址
DERP_DOMAIN=

# ----- 数据库 -----
# SQLite 适合中小规模（< 100 节点），大规模请用 PostgreSQL
DB_TYPE=sqlite3

# ----- 可选功能 -----
# MagicDNS 基础域名（启用后节点可通过 <hostname>.<MAGIC_DNS_DOMAIN> 互相访问）
MAGIC_DNS_DOMAIN=vpn
